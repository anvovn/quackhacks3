# Copy to .env.local and fill in values.

# Auth.js — run: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# FastAPI agent (local: http://localhost:8000, GCP: https://your-api-xxx.run.app)
BACKEND_URL=http://localhost:8000
# Python agent loads SKUs from this Next.js URL (same /api/skus as the dashboard)
# On GCP, set AUTH_URL on both the web and API services to your Cloud Run web URL

# Comma-separated origins for FastAPI CORS (GCP: your Cloud Run web URL)
ALLOWED_ORIGINS=http://localhost:3000

# Google Cloud Console → OAuth 2.0 Client (Web application)
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email + password sign-in (bcrypt hash, never store plain password here)
# Generate hash: npm run hash-password -- yourpassword
AUTH_EMAIL=you@example.com
AUTH_PASSWORD_HASH=
# Optional display name on dashboard
# AUTH_EMAIL_NAME=Your Name

# Or multiple users as JSON (passwordHash for each):
# AUTH_EMAIL_USERS=[{"email":"a@x.com","passwordHash":"$2a$12$...","name":"A"}]

# Self-service signup saves to data/auth-users.json (gitignored)
# Set AUTH_ALLOW_SIGNUP=false to disable /signup
